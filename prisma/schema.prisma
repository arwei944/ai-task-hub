generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  displayName   String?
  role          String   @default("user")
  avatar        String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([username])
  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  progress    Int      @default(0)
  type        String   @default("general")
  phase       String   @default("implementation")
  source      String   @default("manual")
  sourceRef   String?
  assignee    String?
  creator     String?
  parentTaskId String?
  projectId   String?
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project      Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentTask   Task?              @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks     Task[]             @relation("SubTasks")
  dependencies TaskDependency[]  @relation("TaskDependsOn")
  dependents   TaskDependency[]  @relation("TaskDependentOf")
  history      TaskHistory[]
  tags         TaskTag[]
  activities   ActivityLog[]
  @@index([status]) @@index([priority]) @@index([type]) @@index([creator]) @@index([parentTaskId]) @@index([dueDate]) @@index([createdAt]) @@index([status, createdAt]) @@index([status, priority]) @@index([assignee, status]) @@index([projectId]) @@index([phase]) @@index([source])
}

model TaskDependency {
  id          String @id @default(uuid())
  taskId      String
  dependsOnId String
  createdAt   DateTime @default(now())
  task      Task @relation("TaskDependsOn", fields: [taskId], references: [id])
  dependsOn Task @relation("TaskDependentOf", fields: [dependsOnId], references: [id])
  @@unique([taskId, dependsOnId]) @@index([taskId]) @@index([dependsOnId])
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  field     String
  oldValue  String?
  newValue  String?
  actor     String?
  createdAt DateTime @default(now())
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@index([taskId]) @@index([createdAt])
}

model WorkflowTriggerLog {
  id          String   @id @default(uuid())
  workflowId  String
  triggerType String
  payload     String?
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  @@index([workflowId]) @@index([triggerType]) @@index([createdAt])
}

model Tag {
  id     String @id @default(uuid())
  name   String @unique
  color  String @default("#6B7280")
  createdAt DateTime @default(now())
  tasks TaskTag[]
  @@index([name])
}

model TaskTag {
  taskId String
  tagId  String
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([taskId, tagId]) @@index([taskId]) @@index([tagId])
}

model AIAuditLog {
  id         String   @id @default(uuid())
  processor  String
  input      String
  output     String
  model      String
  tokensUsed Int      @default(0)
  duration   Int
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())
  @@index([processor]) @@index([createdAt])
}

model Agent {
  id          String   @id @default(uuid())
  name        String
  description String?
  apiKey      String   @unique
  clientType  String   @default("mcp")
  clientVersion String?
  capabilities String?
  permissionLevel String @default("agent")
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  operations  AgentOperation[]
  projects    Project[]
  activities   ActivityLog[]
  @@index([apiKey]) @@index([isActive]) @@index([clientType]) @@index([createdAt])
}

model AgentOperation {
  id        String   @id @default(uuid())
  agentId   String
  action    String
  target    String?
  details   String?
  success   Boolean  @default(true)
  error     String?
  createdAt DateTime @default(now())
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@index([agentId]) @@index([action]) @@index([createdAt])
}

model Integration {
  id          String   @id @default(uuid())
  type        String
  name        String
  description String?
  config      String
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  syncStatus  String   @default("idle")
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  webhooks    Webhook[]
  @@index([type]) @@index([isActive]) @@index([createdAt])
}

model Webhook {
  id            String   @id @default(uuid())
  integrationId String?
  name          String
  url           String
  secret        String?
  events        String?
  isActive      Boolean  @default(true)
  lastTriggered DateTime?
  triggerCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  @@index([integrationId]) @@index([isActive]) @@index([createdAt])
}

model Notification {
  id          String   @id @default(uuid())
  type        String
  title       String
  message     String
  level       String   @default("info")
  channel     String   @default("system")
  isRead      Boolean  @default(false)
  metadata    String?
  createdAt   DateTime @default(now())
  @@index([type]) @@index([isRead]) @@index([createdAt]) @@index([level])
}

model AppVersion {
  id          String   @id @default(uuid())
  version     String   @unique
  channel     String   @default("stable")
  releaseNotes String?
  checksum    String?
  isCurrent   Boolean  @default(false)
  publishedAt DateTime @default(now())
  @@index([channel]) @@index([isCurrent]) @@index([publishedAt])
}

model ModuleVersion {
  id          String   @id @default(uuid())
  moduleId    String
  version     String
  previousVersion String?
  changelog   String?
  status      String   @default("active")
  configSnapshot String?
  deployedAt  DateTime @default(now())
  @@index([moduleId]) @@index([version]) @@index([status]) @@index([deployedAt])
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  version     String   @default("1.0.0")
  author      String?
  homepage    String?
  license     String?
  entryPoint  String
  config      String?
  isEnabled   Boolean  @default(true)
  settings    String?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([name]) @@index([isEnabled])
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  icon        String?
  owner       String
  settings    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     WorkspaceMember[]
  @@index([owner]) @@index([slug])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member")
  joinedAt    DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@unique([workspaceId, userId]) @@index([workspaceId]) @@index([userId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active")
  phase       String   @default("requirements")
  priority    String   @default("medium")
  techStack   String?
  repository  String?
  creatorId   String?
  creatorType String   @default("agent")
  metadata    String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  activities  ActivityLog[]
  creator     Agent?  @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  @@index([status]) @@index([phase]) @@index([priority]) @@index([creatorId]) @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(uuid())
  projectId   String?
  taskId      String?
  agentId     String?
  action      String
  phase       String?
  title       String
  details     String?
  metadata    String?
  createdAt   DateTime @default(now())
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  @@index([projectId]) @@index([taskId]) @@index([agentId]) @@index([action]) @@index([phase]) @@index([createdAt])
}

model Workflow {
  id            String   @id @default(uuid())
  name          String
  description   String?
  trigger       String   @default("manual")
  triggerConfig String?
  steps         String
  variables     String?
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  retryPolicy       String?
  concurrencyLimit  Int      @default(5)
  timeoutMs         Int      @default(300000)
  soloConfig        String?
  executions        WorkflowExecution[]
  triggerLogs       WorkflowTriggerLog[]
  @@index([isActive]) @@index([createdBy])
}

model WorkflowExecution {
  id               String   @id @default(uuid())
  workflowId       String
  workflowSnapshot String
  status           String   @default("pending")
  currentStepId    String?
  context          String?
  triggerType      String   @default("manual")
  triggeredBy      String?
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  workflow         Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepExecutions     WorkflowStepExecution[]
  feedbackCheckpoints FeedbackCheckpoint[]
  @@index([workflowId]) @@index([status]) @@index([createdAt])
}

model WorkflowStepExecution {
  id          String   @id @default(uuid())
  executionId String
  stepId      String
  stepName    String
  stepType    String
  status      String   @default("pending")
  input       String?
  output      String?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs        Int?
  tokensUsed        Int      @default(0)
  retryCount        Int      @default(0)
  parentStepId      String?
  soloSessionId     String?
  soloCallMode      String?
  soloSubAgent      String?
  createdAt   DateTime @default(now())
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  @@index([executionId]) @@index([status])
}

model FeedbackCheckpoint {
  id              String   @id @default(uuid())
  executionId     String
  stepId          String
  stepName        String
  stepType        String
  checkpointType  String   @default("pre_execute")
  status          String   @default("pending")
  approvalMode    String   @default("auto")
  contextSnapshot String?
  stepOutput      String?
  soloCallRecord  String?
  intervenedBy    String?
  intervention    String?
  rating          Int?
  feedback        String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  execution       WorkflowExecution @relation(fields: [executionId], references: [id])
  @@index([executionId]) @@index([status]) @@index([checkpointType]) @@index([createdAt])
}

model FeedbackRule {
  id              String   @id @default(uuid())
  name            String
  triggerType     String
  triggerConfig   String
  action          String
  actionConfig    String?
  scopeWorkflowId String?
  scopeStepType   String?
  isActive        Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isActive]) @@index([triggerType]) @@index([scopeWorkflowId])
}

model StepFeedback {
  id                String   @id @default(uuid())
  executionId       String
  stepExecutionId   String
  rating            Int
  tags              String?
  comment           String?
  soloReflection    String?
  improvementAction String?
  createdAt         DateTime @default(now())
  @@index([executionId]) @@index([stepExecutionId]) @@index([rating]) @@index([createdAt])
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== User ====================

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  displayName   String?
  role          String   @default("user") // admin, user, agent
  avatar        String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([username])
  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ==================== Task ====================

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("todo") // todo, in_progress, done, closed, deleted
  priority    String   @default("medium") // urgent, high, medium, low
  progress    Int      @default(0) // 0-100
  type        String   @default("general")
  phase       String   @default("implementation") // requirements, planning, architecture, implementation, testing, deployment, review
  source      String   @default("manual") // trae, cursor, windsurf, manual, ai, import, mcp
  sourceRef   String?
  assignee    String?
  creator     String?  // agentId or userId
  parentTaskId String?
  projectId   String?  // 所属项目
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  metadata    String? // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentTask   Task?              @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks     Task[]             @relation("SubTasks")
  dependencies TaskDependency[]  @relation("TaskDependsOn")
  dependents   TaskDependency[]  @relation("TaskDependentOf")
  history      TaskHistory[]
  tags         TaskTag[]
  activities   ActivityLog[]

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([creator])
  @@index([parentTaskId])
  @@index([dueDate])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, priority])
  @@index([assignee, status])
  @@index([projectId])
  @@index([phase])
  @@index([source])
}

// ==================== Task Dependency ====================

model TaskDependency {
  id          String @id @default(uuid())
  taskId      String
  dependsOnId String
  createdAt   DateTime @default(now())

  task      Task @relation("TaskDependsOn", fields: [taskId], references: [id])
  dependsOn Task @relation("TaskDependentOf", fields: [dependsOnId], references: [id])

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

// ==================== Task History ====================

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  field     String   // status, priority, progress, title, description, etc.
  oldValue  String?
  newValue  String?
  actor     String?  // user or agent id
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

// ==================== Workflow Trigger Log ====================

model WorkflowTriggerLog {
  id          String   @id @default(uuid())
  workflowId  String
  triggerType String   // manual | webhook | schedule | event | github-issue | approval
  payload     String?  // JSON
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now())

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([triggerType])
  @@index([createdAt])
}

// ==================== Tag ====================

model Tag {
  id     String @id @default(uuid())
  name   String @unique
  color  String @default("#6B7280")
  createdAt DateTime @default(now())

  tasks TaskTag[]

  @@index([name])
}

// ==================== Task Tag ====================

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

// ==================== AI Audit Log ====================

model AIAuditLog {
  id         String   @id @default(uuid())
  processor  String
  input      String
  output     String
  model      String
  tokensUsed Int      @default(0)
  duration   Int
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())

  @@index([processor])
  @@index([createdAt])
}

// ==================== Agent ====================

model Agent {
  id          String   @id @default(uuid())
  name        String
  description String?
  apiKey      String   @unique
  clientType  String   @default("mcp") // trae, cursor, windsurf, vscode, claude, chatgpt, mcp, api
  clientVersion String? // e.g., "Trae 1.2.0"
  capabilities String? // JSON string: ["task_crud", "ai_extract", ...]
  permissionLevel String @default("agent") // "user" (最高权限) | "agent" (创建者隔离+全局只读)
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  operations  AgentOperation[]
  projects    Project[]
  activities   ActivityLog[]

  @@index([apiKey])
  @@index([isActive])
  @@index([clientType])
  @@index([createdAt])
}

// ==================== Agent Operation ====================

model AgentOperation {
  id        String   @id @default(uuid())
  agentId   String
  action    String   // create_task, update_task, delete_task, extract_tasks, etc.
  target    String?  // task ID or other resource identifier
  details   String?  // JSON string with operation details
  success   Boolean  @default(true)
  error     String?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([action])
  @@index([createdAt])
}

// ==================== Integration ====================

model Integration {
  id          String   @id @default(uuid())
  type        String   // github, feishu, notion, webhook
  name        String
  description String?
  config      String   // JSON string with platform-specific config (tokens, URLs, etc.)
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  syncStatus  String   @default("idle") // idle, syncing, error
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  webhooks    Webhook[]

  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

// ==================== Webhook ====================

model Webhook {
  id            String   @id @default(uuid())
  integrationId String?
  name          String
  url           String   // External URL to receive webhooks
  secret        String?  // HMAC secret for verification
  events        String?  // JSON string: ["push", "issues", ...]
  isActive      Boolean  @default(true)
  lastTriggered DateTime?
  triggerCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([integrationId])
  @@index([isActive])
  @@index([createdAt])
}

// ==================== Notification ====================

model Notification {
  id          String   @id @default(uuid())
  type        String   // task_created, task_overdue, task_status_changed, agent_operation, etc.
  title       String
  message     String
  level       String   @default("info") // info, warning, error, success
  channel     String   @default("system") // system, webhook, browser_push, email, telegram, wechat
  isRead      Boolean  @default(false)
  metadata    String?  // JSON string with additional context
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([level])
}

// ==================== App Version ====================

model AppVersion {
  id          String   @id @default(uuid())
  version     String   @unique // e.g., "1.2.3"
  channel     String   @default("stable") // stable, beta, canary
  releaseNotes String? // Markdown changelog
  checksum    String?  // SHA256 for integrity check
  isCurrent   Boolean  @default(false)
  publishedAt DateTime @default(now())

  @@index([channel])
  @@index([isCurrent])
  @@index([publishedAt])
}

// ==================== Module Version ====================

model ModuleVersion {
  id          String   @id @default(uuid())
  moduleId    String   // e.g., "integration-telegram"
  version     String   // e.g., "1.2.0"
  previousVersion String? // Previous version for rollback
  changelog   String?  // What changed
  status      String   @default("active") // active, rollback, archived
  configSnapshot String? // JSON: module config at this version
  deployedAt  DateTime @default(now())

  @@index([moduleId])
  @@index([version])
  @@index([status])
  @@index([deployedAt])
}

// ==================== Plugin ====================

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  version     String   @default("1.0.0")
  author      String?
  homepage    String?
  license     String?
  entryPoint  String   // Plugin entry file path or module identifier
  config      String?  // JSON: plugin configuration
  isEnabled   Boolean  @default(true)
  settings    String?  // JSON: user-customizable settings
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([isEnabled])
}

// ==================== Workspace ====================

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  icon        String?
  owner       String   // User ID
  settings    String?  // JSON: workspace settings
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]

  @@index([owner])
  @@index([slug])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member") // owner, admin, member, viewer
  joinedAt    DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ==================== Project ====================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active, completed, archived, paused
  phase       String   @default("requirements") // requirements, planning, architecture, implementation, testing, deployment, completed
  priority    String   @default("medium") // urgent, high, medium, low
  techStack   String?  // JSON: ["Next.js", "Prisma", "tRPC"]
  repository  String?  // GitHub/GitLab URL
  creatorId   String?  // Agent ID or User ID
  creatorType String   @default("agent") // agent, user
  metadata    String?  // JSON: project settings, config, etc.
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
  activities  ActivityLog[]
  releases    Release[]
  phaseTransitions PhaseTransition[]
  requirements Requirement[]
  knowledgeEntries KnowledgeEntry[]
  testCases    TestCase[]
  testSuites   TestSuite[]
  creator     Agent?  @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([phase])
  @@index([priority])
  @@index([creatorId])
  @@index([createdAt])
}

// ==================== Activity Log ====================
// Records every action by agents/users - the timeline of the project

model ActivityLog {
  id          String   @id @default(uuid())
  projectId   String?
  taskId      String?
  agentId     String?
  action      String   // project_created, task_created, task_updated, phase_changed, requirement_added, architecture_chosen, code_committed, etc.
  phase       String?  // requirements, planning, architecture, implementation, testing, deployment
  title       String   // Human-readable summary
  details     String?  // JSON: full context of the action
  metadata    String?  // JSON: extra data (diff, file list, etc.)
  createdAt   DateTime @default(now())

  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([taskId])
  @@index([agentId])
  @@index([action])
  @@index([phase])
  @@index([createdAt])
}

// ==================== Workflow ====================

model Workflow {
  id            String   @id @default(uuid())
  name          String
  description   String?
  trigger       String   @default("manual")
  triggerConfig String?
  steps         String
  variables     String?
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  retryPolicy       String?  // JSON: { max: 3, backoff: "exponential", delayMs: 1000 }
  concurrencyLimit  Int      @default(5)
  timeoutMs         Int      @default(300000)
  soloConfig        String?  // JSON: SOLO 默认调用配置
  executions        WorkflowExecution[]
  triggerLogs       WorkflowTriggerLog[]
  @@index([isActive])
  @@index([createdBy])
}

model WorkflowExecution {
  id               String   @id @default(uuid())
  workflowId       String
  workflowSnapshot String
  status           String   @default("pending")
  currentStepId    String?
  context          String?
  triggerType      String   @default("manual")
  triggeredBy      String?
  startedAt        DateTime?
  completedAt      DateTime?
  error            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  workflow         Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepExecutions     WorkflowStepExecution[]
  feedbackCheckpoints FeedbackCheckpoint[]
  @@index([workflowId])
  @@index([status])
  @@index([createdAt])
}

model WorkflowStepExecution {
  id          String   @id @default(uuid())
  executionId String
  stepId      String
  stepName    String
  stepType    String
  status      String   @default("pending")
  input       String?
  output      String?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs        Int?
  tokensUsed        Int      @default(0)
  retryCount        Int      @default(0)
  parentStepId      String?
  soloSessionId     String?
  soloCallMode      String?
  soloSubAgent      String?
  createdAt   DateTime @default(now())
  execution   WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  @@index([executionId])
  @@index([status])
}

// ==================== Feedback Checkpoint ====================

model FeedbackCheckpoint {
  id              String   @id @default(uuid())
  executionId     String
  stepId          String
  stepName        String
  stepType        String
  checkpointType  String   @default("pre_execute") // pre_execute | post_execute | timeout | error | manual
  status          String   @default("pending") // pending | approved | rejected | skipped | modified | timeout_expired
  approvalMode    String   @default("auto") // auto | notify | block | smart
  contextSnapshot String?
  stepOutput      String?
  soloCallRecord  String?
  intervenedBy    String?  // "user" | "solo" | "auto_rule"
  intervention    String?
  rating          Int?
  feedback        String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  execution       WorkflowExecution @relation(fields: [executionId], references: [id])

  @@index([executionId])
  @@index([status])
  @@index([checkpointType])
  @@index([createdAt])
}

// ==================== Feedback Rule ====================

model FeedbackRule {
  id              String   @id @default(uuid())
  name            String
  triggerType     String   // step_type | duration | token_cost | rating | error_rate | always
  triggerConfig   String   // JSON
  action          String   // block | notify | skip | modify | escalate
  actionConfig    String?
  scopeWorkflowId String?
  scopeStepType   String?
  isActive        Boolean  @default(true)
  createdBy       String?  // "user" | "solo"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([triggerType])
  @@index([scopeWorkflowId])
}

// ==================== Step Feedback ====================

model StepFeedback {
  id                String   @id @default(uuid())
  executionId       String
  stepExecutionId   String
  rating            Int      // 1-5
  tags              String?  // JSON array
  comment           String?
  soloReflection    String?  // JSON
  improvementAction String?  // JSON
  createdAt         DateTime @default(now())

  @@index([executionId])
  @@index([stepExecutionId])
  @@index([rating])
  @@index([createdAt])
}

// ==================== Release ====================

model Release {
  id            String   @id @default(uuid())
  projectId     String
  version       String   // semantic version: "1.0.0"
  previousVersion String? // previous release version
  title         String   // "v1.0.0 - Initial Release"
  description   String?  // detailed release description
  status        String   @default("draft") // draft, review, approved, published, archived, rolled_back
  channel       String   @default("stable") // stable, beta, canary, hotfix
  type          String   @default("minor") // major, minor, patch, prerelease, hotfix
  releaseNotes  String?  // Markdown changelog
  metadata      String?  // JSON: additional data (commit hash, build info, etc.)
  publishedAt   DateTime?
  archivedAt    DateTime?
  createdBy      String?  // agentId or userId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changelogs    ReleaseChangelog[]
  tags          ReleaseTag[]
  approvals     ReleaseApproval[]
  milestones    ReleaseMilestone[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([status])
  @@index([channel])
  @@index([type])
  @@index([publishedAt])
  @@index([createdAt])
}

// ==================== Release Changelog ====================

model ReleaseChangelog {
  id          String   @id @default(uuid())
  releaseId   String
  category    String   // added, changed, fixed, deprecated, removed, security, performance, docs, refactor, test, chore
  title       String   // "Fixed login bug"
  description String?  // detailed description
  impact      String   @default("patch") // major, minor, patch
  metadata    String?  // JSON: related issues, PRs, etc.
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId])
  @@index([category])
  @@index([order])
}

// ==================== Release Tag ====================

model ReleaseTag {
  id        String @id @default(uuid())
  releaseId String
  name      String // "breaking", "feature", "bugfix", "security", "documentation", etc.
  color     String @default("#6B7280")

  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId])
  @@index([name])
}

// ==================== Release Approval ====================

model ReleaseApproval {
  id          String   @id @default(uuid())
  releaseId   String
  approverId  String?  // agentId or userId
  role        String   @default("reviewer") // reviewer, admin, auto
  decision    String   @default("pending") // pending, approved, rejected, skipped
  comment     String?
  createdAt   DateTime @default(now())
  decidedAt   DateTime?

  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId])
  @@index([decision])
  @@index([createdAt])
}

// ==================== Release Milestone ====================

model ReleaseMilestone {
  id          String   @id @default(uuid())
  releaseId   String
  name        String   // "Code Freeze", "QA Complete", "Deployed"
  status      String   @default("pending") // pending, in_progress, completed, skipped
  completedAt DateTime?
  createdAt   DateTime @default(now())

  release     Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId])
  @@index([status])
}

// ==================== Event Store ====================

model EventStore {
  id        String   @id @default(cuid())
  eventType String
  payload   String
  source    String?
  timestamp DateTime @default(now())
  version   Int      @default(1)

  @@index([eventType, timestamp])
  @@index([source, timestamp])
}

// ==================== Phase Transition ====================

model PhaseTransition {
  id          String   @id @default(cuid())
  projectId   String
  fromPhase   String
  toPhase     String
  triggeredBy String?
  reason      String?
  status      String   @default("pending") // pending, approved, rejected, completed
  metadata    String?  // JSON - additional context
  createdAt   DateTime @default(now())
  completedAt DateTime?

  project     Project  @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
}

// ==================== Requirement ====================

model Requirement {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String
  type        String   @default("feature")
  priority    Int      @default(0)
  status      String   @default("draft")
  complexity  String?
  acceptance  String?
  source      String?
  parentReqId String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id])
  parent      Requirement?  @relation("ReqHierarchy", fields: [parentReqId], references: [id])
  children    Requirement[] @relation("ReqHierarchy")
  tags        RequirementTag[]

  @@index([projectId, status])
  @@index([parentReqId])
}

// ==================== Requirement Tag ====================

model RequirementTag {
  id             String       @id @default(cuid())
  requirementId  String
  name           String
  createdAt      DateTime     @default(now())

  requirement    Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, name])
  @@index([name])
}

// ==================== Knowledge Entry ====================

model KnowledgeEntry {
  id          String   @id @default(cuid())
  projectId   String?
  type        String   @default("lesson_learned")
  title       String
  content     String
  tags        String   @default("[]")
  sourceEvent String?
  aiGenerated Boolean  @default(false)
  usefulness  Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([type])
  @@index([tags])
}

// ==================== Test Case ====================

model TestCase {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  type        String   @default("functional") // functional, unit, integration, e2e, performance
  priority    String   @default("medium")     // low, medium, high, critical
  status      String   @default("draft")      // draft, ready, passed, failed, skipped, blocked
  taskId      String?
  requirementId String?
  steps       String?  @default("[]")         // JSON array of test steps
  expectedResult String?
  createdBy   String?
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id])
  executions  TestExecution[]

  @@index([projectId, status])
  @@index([taskId])
}

// ==================== Test Execution ====================

model TestExecution {
  id          String   @id @default(cuid())
  testCaseId  String
  status      String   @default("pending") // pending, running, passed, failed, skipped
  duration    Int?     // ms
  output      String?
  errorMessage String?
  executedBy  String?
  environment String?  // local, staging, production
  createdAt   DateTime @default(now())

  testCase    TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@index([testCaseId, createdAt])
}

// ==================== Test Suite ====================

model TestSuite {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  testCaseIds String   @default("[]") // JSON array of test case IDs
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

// ==================== Deployment Environment ====================

model DeploymentEnvironment {
  id                String   @id @default(cuid())
  name              String   @unique          // dev, staging, production
  displayName       String
  description       String?
  baseUrl           String                    // Environment base URL
  config            String   @default("{}")   // JSON: environment config (env vars, etc.)
  isActive          Boolean  @default(true)
  healthStatus      String   @default("unknown") // healthy, degraded, unhealthy, unknown
  lastDeploymentAt  DateTime?
  order             Int      @default(0)      // Sort order
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deployments       Deployment[]
  healthChecks      HealthCheck[]

  @@index([isActive])
  @@index([order])
}

// ==================== Deployment ====================

model Deployment {
  id              String   @id @default(cuid())
  environmentId   String
  projectId       String?
  version         String                    // Deployed version (semver)
  strategy        String   @default("rolling") // rolling, blue_green, canary, recreate
  status          String   @default("pending") // pending, queued, building, deploying, verifying, running, failed, rolled_back, cancelled
  description     String?
  triggeredBy     String?                   // agentId or userId
  config          String?                   // JSON: deployment config overrides
  startedAt       DateTime?
  completedAt     DateTime?
  duration        Int?                      // Duration in ms
  rollbackFromId  String?                   // If this is a rollback, reference to original deployment
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  environment     DeploymentEnvironment @relation(fields: [environmentId], references: [id])
  logs            DeploymentLog[]

  @@index([environmentId, createdAt])
  @@index([projectId])
  @@index([status])
  @@index([version])
  @@index([triggeredBy])
}

// ==================== Deployment Log ====================

model DeploymentLog {
  id            String   @id @default(cuid())
  deploymentId  String
  level         String   @default("info")   // info, warn, error, debug
  message       String
  metadata      String?                     // JSON: additional context
  timestamp     DateTime @default(now())

  deployment    Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, timestamp])
}

// ==================== Health Check ====================

model HealthCheck {
  id                 String   @id @default(cuid())
  environmentId      String
  name               String
  type               String   @default("http") // http, tcp, process, custom
  config             String   @default("{}")   // JSON: check config (url, timeout, interval, etc.)
  isActive           Boolean  @default(true)
  lastStatus         String   @default("unknown") // healthy, degraded, unhealthy, unknown
  lastCheckAt        DateTime?
  consecutiveFailures Int     @default(0)
  createdAt          DateTime @default(now())

  environment        DeploymentEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId])
  @@index([isActive])
}

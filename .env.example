# ============================================================
# AI Task Hub - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# cp .env.example .env
#

# ---- Required for AI features ----

# OpenAI API Key (required for AI task extraction, decomposition, etc.)
OPENAI_API_KEY=

# OpenAI-compatible API base URL (optional, defaults to OpenAI)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default AI model
AI_ENGINE_DEFAULT_MODEL=gpt-4o

# ---- Authentication ----

# JWT Secret (auto-generated and persisted to /data/.jwt_secret if not set)
# JWT_SECRET=

# Admin password (auto-generated if not set, check startup logs)
# ADMIN_PASSWORD=

# ---- Database ----

# SQLite database path (default: file:./prisma/dev.db)
# DATABASE_URL=file:./prisma/dev.db

# ---- CORS ----

# Allowed origins (comma-separated, default: http://localhost:3000,http://localhost:7860)
# CORS_ORIGINS=http://localhost:3000,http://localhost:7860

# ---- Webhook Security ----

# Webhook signing secret (if set, all webhook requests must include valid X-Webhook-Signature)
# WEBHOOK_SECRET=

# ---- Notification Channels (optional) ----

# Telegram Bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFY_CHAT_ID=

# WeChat Work
# WECHAT_BOT_WEBHOOK_URL=

# Email (SMTP)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL_FROM=
# NOTIFY_EMAIL_TO=

# Web Push (auto-generated if not set)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=

# ---- SOLO Bridge (optional) ----

# SOLO_MCP_ENDPOINT=http://localhost:3001/mcp
# SOLO_REST_ENDPOINT=http://localhost:3001/api/solo/call
# SOLO_DEFAULT_MODE=mcp
# SOLO_TIMEOUT_MS=30000

# ---- HuggingFace Spaces (deployment only) ----

# HF_TOKEN=
# HF_REPO=arwei944/ai-task-hub
